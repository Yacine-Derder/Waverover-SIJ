#!/usr/bin/env python3

import curses
import math
import time

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32MultiArray


class ManualLRPublisher(Node):
    def __init__(self):
        super().__init__("manual_lr_ui")
        self.declare_parameter("topic", "manual_lr")
        self.declare_parameter("publish_rate_hz", 10.0)
        self.declare_parameter("step", 0.05)
        self.declare_parameter("large_step", 0.10)
        self.declare_parameter("min_speed", -0.5)
        self.declare_parameter("max_speed", 0.5)

        self.topic = self.get_parameter("topic").value
        self.publish_rate_hz = float(self.get_parameter("publish_rate_hz").value)
        self.step = float(self.get_parameter("step").value)
        self.large_step = float(self.get_parameter("large_step").value)
        self.min_speed = float(self.get_parameter("min_speed").value)
        self.max_speed = float(self.get_parameter("max_speed").value)

        self.publish_rate_hz = max(self.publish_rate_hz, 0.1)
        if self.min_speed > self.max_speed:
            self.min_speed, self.max_speed = self.max_speed, self.min_speed

        self.publisher = self.create_publisher(Float32MultiArray, self.topic, 10)

    def clamp(self, value):
        if not math.isfinite(value):
            return 0.0
        return min(max(value, self.min_speed), self.max_speed)

    def publish(self, left, right):
        msg = Float32MultiArray()
        msg.data = [float(self.clamp(left)), float(self.clamp(right))]
        self.publisher.publish(msg)


def slider(value, minimum, maximum, width=34):
    if maximum <= minimum:
        maximum = minimum + 1.0
    ratio = (value - minimum) / (maximum - minimum)
    filled = min(max(int(round(ratio * width)), 0), width)
    return "[" + ("#" * filled).ljust(width, "-") + "]"


def draw(screen, node, left, right):
    screen.erase()
    height, width = screen.getmaxyx()
    title = "WaveRover manual L/R wheel-speed calibration"
    if width >= len(title):
        screen.addstr(0, 0, title, curses.A_BOLD)

    rows = [
        f"Topic: {node.topic}   Publish: {node.publish_rate_hz:.1f} Hz",
        "",
        f"L {left:+.2f} {slider(left, node.min_speed, node.max_speed)}",
        f"R {right:+.2f} {slider(right, node.min_speed, node.max_speed)}",
        "",
        "Controls:",
        "  a/y       left +/-",
        "  k/m       right +/-",
        "  w/s       both +/-",
        "  A/Y K/M   larger steps",
        "  0 or space reset",
        "  q         zero and quit",
    ]

    for idx, text in enumerate(rows, start=2):
        if idx >= height:
            break
        screen.addstr(idx, 0, text[: max(0, width - 1)])

    screen.refresh()


def run_ui(screen, node):
    curses.curs_set(0)
    screen.nodelay(True)
    screen.timeout(50)

    left = 0.0
    right = 0.0
    next_publish = 0.0
    period = 1.0 / node.publish_rate_hz
    changed = True

    try:
        while rclpy.ok():
            draw(screen, node, left, right)
            key = screen.getch()

            if key in (ord("q"), ord("Q")):
                break
            if key == ord("a"):
                left = node.clamp(left + node.step)
                changed = True
            elif key == ord("y"):
                left = node.clamp(left - node.step)
                changed = True
            elif key == ord("k"):
                right = node.clamp(right + node.step)
                changed = True
            elif key == ord("m"):
                right = node.clamp(right - node.step)
                changed = True
            elif key == ord("A"):
                left = node.clamp(left + node.large_step)
                changed = True
            elif key == ord("Y"):
                left = node.clamp(left - node.large_step)
                changed = True
            elif key == ord("K"):
                right = node.clamp(right + node.large_step)
                changed = True
            elif key == ord("M"):
                right = node.clamp(right - node.large_step)
                changed = True
            elif key == ord("w"):
                left = node.clamp(left + node.step)
                right = node.clamp(right + node.step)
                changed = True
            elif key == ord("s"):
                left = node.clamp(left - node.step)
                right = node.clamp(right - node.step)
                changed = True
            elif key in (ord("0"), ord(" ")):
                left = 0.0
                right = 0.0
                changed = True

            now = time.monotonic()
            if changed or now >= next_publish:
                node.publish(left, right)
                changed = False
                next_publish = now + period

            rclpy.spin_once(node, timeout_sec=0.0)
    finally:
        for _ in range(3):
            node.publish(0.0, 0.0)
            rclpy.spin_once(node, timeout_sec=0.0)
            time.sleep(0.05)


def main():
    rclpy.init()
    node = ManualLRPublisher()
    try:
        curses.wrapper(run_ui, node)
    except KeyboardInterrupt:
        node.publish(0.0, 0.0)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
